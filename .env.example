# Neo4j (the docker-compose stack reads NEO4J_PASSWORD)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=companybrain

# Live Paperclip ingestion (etl_live.py) — point at your own Paperclip instance
PAPERCLIP_BASE_URL=http://127.0.0.1:3101
PAPERCLIP_HOST=localhost:3101
PAPERCLIP_COMPANY_ID=          # your Paperclip company UUID (required for etl_live.py)
