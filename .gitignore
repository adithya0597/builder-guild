# Secrets & env
.env
.env.*
!.env.example
*.key
*.pem
*credential*
*secret*
auth.json
*client_secret*.json
*token*

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Neo4j / data / dumps
*.db
*.sqlite*
data/
dumps/

# Founder-gate / calibration outputs (may hold PRIVATE graph data — never commit to the public repo).
# cal3_fit.py / cal4_sweep.py default --out/--ckpt here; a founder run on private golds should pass an
# explicit private --out, but these guards stop an accidental leak if the default path is used.
03-evals/src/cal3_fit_results.json
03-evals/src/cal4_results.json
03-evals/src/cal3_judge.jsonl
03-evals/src/cal4_progress.jsonl

# gt2_draft.py golden DRAFT outputs — machine-generated, pending human validation. Only the
# human-validated 03-evals/example_golden.jsonl is committed (2fj). NOTE: golden_v1_draft.jsonl +
# golden_v1_review.md stay TRACKED on purpose — the founder grant flow reads them (README founder gate).
03-evals/src/golden_v0_draft.jsonl
03-evals/src/golden_v0_review.md

# Logs
*.log
logs/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
graphify-out/

# Local audits — may document unpatched gaps; keep out of the public tree until fixed/genericized
audits/

# Beads issue tracker — local project management; issues.jsonl references git-ignored audits/ and
# internal decisions, so keep the whole tracker out of the public repo.
.beads/

# Conductor: monorepo harness is symlinked into worktrees at setup, never committed (public repo).
# Pattern has NO trailing slash so it also ignores a SYMLINK named .claude (git treats symlinks as files).
.claude
.conductor/settings.local.toml
